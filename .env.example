# Database
DATABASE_URL=postgresql://studyapp:CHANGE_ME@postgres:5432/studyapp
POSTGRES_USER=studyapp
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=studyapp

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_ISSUER=https://<your-clerk-instance>.clerk.accounts.dev
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# AI (used in Plan 2)
DEEPSEEK_API_KEY=
AI_PROVIDER=deepseek

# Code execution (used in Plan 2)
JUDGE0_API_KEY=
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# Payments (disabled)
PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin
ADMIN_USER_IDS=

# Backend URL (used by Next.js to talk to FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://fastapi:8000
